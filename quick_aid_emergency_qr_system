<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quick-AID | Ultra AI Emergency Profile</title>

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>

<style>
.glow { box-shadow: 0 0 30px rgba(255,0,0,0.7); }
.pulse { animation: pulse 1.5s infinite; }
@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
.risk-bar { height: 25px; border-radius: 12px; transition: width 0.5s, background-color 0.5s; color: white; text-align: center; font-weight: bold; line-height: 25px; }
.scrollable { max-height: 150px; overflow-y: auto; }
</style>
</head>

<body id="body" class="bg-gray-100 font-sans transition duration-500">

<div class="max-w-lg mx-auto bg-white min-h-screen shadow-2xl rounded-xl p-5">

<!-- HEADER -->
<div class="bg-red-600 text-white text-center p-8 rounded-b-3xl">
  <div class="text-7xl mb-3">🚑</div>
  <h1 class="text-3xl font-bold">Quick-AID</h1>
  <p class="text-lg">Ultra AI Emergency System</p>

  <img id="profileImg" src="https://via.placeholder.com/120"
       class="w-28 h-28 rounded-full mx-auto border-4 border-white mt-4">

  <h2 class="text-2xl font-bold mt-3" id="patientName">Rahul Sharma</h2>

  <div class="mt-3 bg-white text-red-600 px-5 py-2 rounded-full font-bold" id="bloodGroup">
    Blood Group: O+
  </div>

  <div class="mt-5 space-x-3">
    <button onclick="confirmSOS()" 
      class="pulse bg-yellow-300 text-black px-5 py-2 rounded-full font-bold">
      🚨 SOS
    </button>

    <button onclick="toggleDarkMode()" 
      class="bg-black text-white px-5 py-2 rounded-full">
      🌙 Mode
    </button>
  </div>
</div>

<!-- CONTENT -->
<div class="p-6 space-y-5">

<!-- AI RISK -->
<div id="riskBox" class="risk-bar bg-red-500 w-full glow">
  🤖 AI Risk: HIGH
</div>

<!-- LOCATION -->
<div class="bg-green-200 p-4 rounded-xl flex justify-between">
  <span>📍 Live Location</span>
  <button onclick="openMap()" class="underline">Open Map</button>
</div>

<!-- ALLERGIES -->
<div class="bg-yellow-100 p-5 rounded-xl border-l-4 border-yellow-500">
  <h2 class="text-xl font-bold text-yellow-600 mb-3">⚠️ Allergies</h2>
  <div class="scrollable" id="allergyList">
    <p>🚫 Penicillin</p>
    <p>🚫 Peanuts</p>
  </div>
</div>

<!-- MEDICAL -->
<div class="bg-white p-5 rounded-xl border-l-4 border-red-400">
  <h2 class="text-xl font-bold text-red-500 mb-3">❤️ Medical</h2>
  <div class="scrollable" id="medicalList">
    <p>Diabetes (HIGH)</p>
    <p>Hypertension (MEDIUM)</p>
    <p>Asthma (LOW)</p>
  </div>
</div>

<!-- MEDICATION -->
<div class="bg-white p-5 rounded-xl border-l-4 border-blue-400">
  <h2 class="text-xl font-bold text-blue-500 mb-3">💊 Medication</h2>
  <div class="scrollable" id="medicationList">
    <p>Metformin</p>
    <p>Lisinopril</p>
    <p>Inhaler</p>
  </div>
</div>

<!-- CAMERA -->
<div class="bg-gray-100 p-4 rounded-xl text-center">
  <button onclick="startCamera()" class="bg-blue-500 text-white px-4 py-2 rounded">
    📷 Start Camera
  </button>
  <button onclick="capturePhoto()" class="bg-green-500 text-white px-4 py-2 rounded mt-2">
    📸 Capture Patient Photo
  </button>
  <textarea id="injuryNote" placeholder="Describe injury..." class="w-full mt-2 p-2 rounded"></textarea>
  <video id="video" class="hidden rounded w-full mt-2" autoplay></video>
  <canvas id="canvas" class="hidden"></canvas>
  <img id="photo" class="mt-3 mx-auto rounded shadow"/>
  <button id="downloadBtn" class="bg-purple-500 text-white px-4 py-2 rounded mt-2 hidden" onclick="downloadInjury()">
    💾 Download Photo & Note
  </button>
</div>

<!-- GUARDIAN -->
<div class="bg-purple-100 p-5 rounded-xl border-l-4 border-purple-500">
  <h2 class="text-xl font-bold text-purple-600 mb-3">👨‍👩‍👧 Guardian</h2>
  <div class="flex justify-between mb-2">
    <span>Father</span>
    <button onclick="sendWhatsApp('919876500000')" class="bg-green-500 text-white px-2 rounded">WhatsApp</button>
  </div>
  <div class="flex justify-between">
    <span>Mother</span>
    <button onclick="sendWhatsApp('919123456789')" class="bg-green-500 text-white px-2 rounded">WhatsApp</button>
  </div>
</div>

<!-- QR -->
<div class="text-center mt-5">
  <p class="font-bold mb-2">Scan QR to Open Website</p>
  <canvas id="qrCode" class="mx-auto"></canvas>
</div>

</div>

<!-- FOOTER -->
<div class="text-center text-sm p-3 text-gray-500">
  🚀 AI Powered Emergency System | <strong>Made by Mansi Bavaliya with help of Shivani Chaurasiya</strong>
</div>

</div>

<script>
// Patient Data
let patient = {
  name: "Rahul Sharma",
  blood: "O+",
  allergies: ["Penicillin", "Peanuts"],
  medical: ["Diabetes (HIGH)", "Hypertension (MEDIUM)", "Asthma (LOW)"],
  medication: ["Metformin", "Lisinopril", "Inhaler"],
  guardians: [
    { name: "Father", phone: "919876500000" },
    { name: "Mother", phone: "919123456789" }
  ],
  photo: null,
  injuryNote: null
};

// QR Code pointing to live GitHub Pages URL
function generateQRCode() {
  const websiteURL = "https://mansibavaliya.github.io/quick-aid-emergency-qr-system/";
  QRCode.toCanvas(document.getElementById('qrCode'), websiteURL, { width: 140 }, function(err) {
    if(err) console.error(err);
  });
}
generateQRCode();

// Dark Mode
function toggleDarkMode() {
  document.getElementById("body").classList.toggle("bg-black");
  document.getElementById("body").classList.toggle("text-white");
}

// Map
function openMap() {
  navigator.geolocation.getCurrentPosition(pos => {
    let lat = pos.coords.latitude;
    let lon = pos.coords.longitude;
    window.open(`https://maps.google.com/?q=${lat},${lon}`);
  });
}

// SOS
function confirmSOS() {
  if(confirm("Are you sure you want to send SOS?")) sendSOS();
}
function sendSOS() {
  speakAlert();
  patient.guardians.forEach(g => sendWhatsApp(g.phone));
}
function speakAlert() {
  let msg = `Emergency! Patient ${patient.name} requires immediate attention.`;
  window.speechSynthesis.speak(new SpeechSynthesisUtterance(msg));
}
function sendWhatsApp(phone) {
  navigator.geolocation.getCurrentPosition(pos => {
    let link = `https://maps.google.com/?q=${pos.coords.latitude},${pos.coords.longitude}`;
    let msg = `🚨 EMERGENCY!\nPatient: ${patient.name}\nBlood: ${patient.blood}\nAllergies: ${patient.allergies.join(", ")}\nLocation: ${link}`;
    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`);
  });
}

// AI Risk
function calculateRisk() {
  let score = 100 - (patient.allergies.length*15) - (patient.medical.length*10);
  let risk = "LOW";
  let color = "bg-green-400";
  if(score<50){ risk="HIGH"; color="bg-red-500 glow";}
  else if(score<75){ risk="MEDIUM"; color="bg-orange-400";}
  let box = document.getElementById("riskBox");
  box.innerText = `🤖 AI Risk: ${risk}`;
  box.className = `risk-bar ${color}`;
}
calculateRisk();

// Camera
let video = document.getElementById("video");
function startCamera() {
  video.classList.remove("hidden");
  navigator.mediaDevices.getUserMedia({ video: true }).then(stream => video.srcObject = stream);
}
function capturePhoto() {
  if(video.srcObject){
    let canvas = document.getElementById("canvas");
    let ctx = canvas.getContext("2d");
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    ctx.drawImage(video, 0, 0);
    let image = canvas.toDataURL();
    document.getElementById("photo").src = image;

    patient.photo = image;
    patient.injuryNote = document.getElementById("injuryNote").value;

    // Save photo + note with timestamp to localStorage
    const record = {
      image,
      note: patient.injuryNote,
      timestamp: new Date().toLocaleString()
    };
    localStorage.setItem("injuryRecord", JSON.stringify(record));

    generateQRCode();
    document.getElementById("downloadBtn").classList.remove("hidden");
  } else { 
    alert("Please start the camera first!"); 
  }
}

// Load saved photo + note on page load
function loadSavedInjury() {
  const saved = JSON.parse(localStorage.getItem("injuryRecord"));
  if(saved){
    document.getElementById("photo").src = saved.image;
    document.getElementById("injuryNote").value = saved.note;
    document.getElementById("downloadBtn").classList.remove("hidden");
  }
}
window.onload = loadSavedInjury;

// Download photo + note
function downloadInjury() {
  if(!patient.photo) return;
  let a = document.createElement("a");
  a.href = patient.photo; a.download = "patient_photo.png"; a.click();

  let noteLink = document.createElement("a");
  let blob = new Blob([`Injury Note:\n${patient.injuryNote || ''}`], { type: "text/plain" });
  noteLink.href = URL.createObjectURL(blob);
  noteLink.download = "injury_note.txt"; noteLink.click();
}
</script>

</body>
</html>
